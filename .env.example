# ──────────────────────────────────────────────────────────────────────────────
# Beauty Booking OS — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# In production, set these in Vercel dashboard (NOT in a committed .env file).
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...          # Public — safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...              # SECRET — server-side only, never expose
DATABASE_URL=postgresql://postgres.zjviarizzyjeeyumpuyx:Yigitcan4642@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                       # SECRET

# ── Salon Configuration ───────────────────────────────────────────────────────
DEFAULT_CLIENT_SLUG=demo-salon                     # Matches folder under clients/ (server-side)
NEXT_PUBLIC_DEFAULT_CLIENT_SLUG=demo-salon         # Same value — exposed to BookingForm client component
NEXT_PUBLIC_SALON_NAME=Vienna Glow Studio          # Displayed in UI
NEXT_PUBLIC_SALON_DOMAIN=https://viennaglowstudio.at  # Used for CORS headers
NEXT_PUBLIC_CONTACT_EMAIL=hello@viennaglowstudio.at   # Displayed on thank-you page
DEMO_CLIENT_ID=00000000-0000-0000-0000-000000000001       # UUID from clients table (server-side)
NEXT_PUBLIC_DEMO_CLIENT_ID=00000000-0000-0000-0000-000000000001  # Same — exposed to BookingForm

# ── Security ──────────────────────────────────────────────────────────────────
ADMIN_SECRET=change-me-to-a-strong-random-string-min-32-chars   # Admin panel auth
WEBHOOK_SECRET=change-me-to-another-strong-random-string        # Job endpoint auth

# ── Webhook Verification (Meta / WhatsApp / Instagram) ────────────────────────
WHATSAPP_APP_SECRET=                               # From Meta App Dashboard — for HMAC verification
WHATSAPP_VERIFY_TOKEN=                             # Your chosen token for webhook registration
INSTAGRAM_APP_SECRET=                              # From Meta App Dashboard — for HMAC verification
INSTAGRAM_VERIFY_TOKEN=                            # Your chosen token for webhook registration

# ── Messaging ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                              # For transactional email (Resend.com)
WHATSAPP_API_TOKEN=                                # WhatsApp Business API token (V2)
WHATSAPP_PHONE_NUMBER_ID=                          # WhatsApp phone number ID (V2)
INSTAGRAM_ACCESS_TOKEN=                            # Instagram Graph API token (V2)

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development=production                         # Set to "production" in Vercel automatically

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=30
# In production with multiple Vercel instances, switch to Redis-backed rate limiter.
# REDIS_URL=redis://...
